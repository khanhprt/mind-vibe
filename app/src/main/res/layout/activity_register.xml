<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    tools:context=".RegisterActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- Back button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <ImageButton
                    android:id="@+id/buttonBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="@color/purple_dark"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="Back" />

            </LinearLayout>

            <!-- Logo card -->
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imageViewLogo"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_app_logo_mindvibe" />

            </androidx.cardview.widget.CardView>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tạo tài khoản"
                android:textColor="@color/purple_dark"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="6dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bắt đầu hành trình chăm sóc tâm lý"
                android:textColor="@color/purple_muted"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="40dp" />

            <!-- Email label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="@color/purple_label"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Email field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutEmail"
                style="@style/MindVibeInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_mail"
                app:startIconTint="@color/purple_icon">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="your@email.com"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/purple_dark"
                    android:textColorHint="@color/purple_hint"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MẬT KHẨU"
                android:textColor="@color/purple_label"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Password field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutPassword"
                style="@style/MindVibeInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/purple_icon"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/purple_icon">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Ít nhất 8 ký tự"
                    android:inputType="textPassword"
                    android:textColor="@color/purple_dark"
                    android:textColorHint="@color/purple_hint"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm Password label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="XÁC NHẬN MẬT KHẨU"
                android:textColor="@color/purple_label"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Confirm Password field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutConfirmPassword"
                style="@style/MindVibeInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/purple_icon"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/purple_icon">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Nhập lại mật khẩu"
                    android:inputType="textPassword"
                    android:textColor="@color/purple_dark"
                    android:textColorHint="@color/purple_hint"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Register button -->
            <Button
                android:id="@+id/buttonRegister"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Đăng ký"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:backgroundTint="@color/purple_primary"
                app:cornerRadius="14dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:layout_marginBottom="28dp" />

            <!-- Login link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã có tài khoản? "
                    android:textColor="@color/purple_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/textViewLoginLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng nhập"
                    android:textColor="@color/purple_primary"
                    android:textStyle="bold"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
