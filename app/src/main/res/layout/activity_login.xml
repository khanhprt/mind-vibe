<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="72dp"
            android:paddingBottom="40dp">

            <!-- Logo card -->
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="true"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imageViewLogo"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_app_logo_mindvibe" />

            </androidx.cardview.widget.CardView>

            <!-- App name -->
            <TextView
                android:id="@+id/textViewAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MindVibe"
                android:textColor="@color/purple_dark"
                android:textSize="26sp"
                android:textStyle="normal"
                android:letterSpacing="-0.02"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp" />

            <!-- Tagline -->
            <TextView
                android:id="@+id/textViewTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người bạn đồng hành tâm lý của bạn"
                android:textColor="@color/purple_muted"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="40dp" />

            <!-- Email label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="@color/purple_label"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Email field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutEmail"
                style="@style/MindVibeInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_mail"
                app:startIconTint="@color/purple_icon">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="your@email.com"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/purple_dark"
                    android:textColorHint="@color/purple_hint"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MẬT KHẨU"
                android:textColor="@color/purple_label"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Password field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutPassword"
                style="@style/MindVibeInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/purple_icon"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/purple_icon">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:textColor="@color/purple_dark"
                    android:textColorHint="@color/purple_hint"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Forgot password -->
            <TextView
                android:id="@+id/textViewForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Quên mật khẩu?"
                android:textColor="@color/purple_primary"
                android:textSize="13sp"
                android:layout_marginBottom="28dp"
                android:layout_alignParentEnd="true" />

            <!-- Login button -->
            <Button
                android:id="@+id/buttonLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Đăng nhập"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:letterSpacing="0.01"
                android:backgroundTint="@color/purple_primary"
                app:cornerRadius="10dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:layout_marginBottom="20dp" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/purple_divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="hoặc"
                    android:textColor="@color/purple_muted"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/purple_divider" />

            </LinearLayout>

            <!-- Google sign in button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonGoogle"
                style="@style/MindVibeOutlineButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Tiếp tục với Google"
                app:icon="@drawable/ic_google"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:layout_marginBottom="36dp" />

            <!-- Register link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa có tài khoản? "
                    android:textColor="@color/purple_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/textViewRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng ký ngay"
                    android:textColor="@color/purple_primary"
                    android:textStyle="bold"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Author credit -->
    <TextView
        android:id="@+id/textViewAuthor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="khanh.ng95@gmail.com"
        android:textColor="@color/purple_hint"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
