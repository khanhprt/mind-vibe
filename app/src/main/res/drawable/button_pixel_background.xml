<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/pixel_green_dark"/>
            <stroke android:width="4dp" android:color="@color/pixel_green_dark"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/pixel_green_medium"/>
            <stroke android:width="4dp" android:color="@color/pixel_green_dark"/>
        </shape>
    </item>
</selector>