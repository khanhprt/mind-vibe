<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MindVibe" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/pixel_green_medium</item>
        <item name="colorPrimaryVariant">@color/pixel_green_dark</item>
        <item name="colorOnPrimary">@color/pixel_green_very_light</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/pixel_green_light</item>
        <item name="colorSecondaryVariant">@color/pixel_green_medium</item>
        <item name="colorOnSecondary">@color/pixel_green_dark</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Theme for the Login Activity with no action bar -->
    <style name="Theme.MindVibe.NoActionBar" parent="Theme.MindVibe">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>